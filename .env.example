# ==============================
# PanHub 部署环境变量示例
# 复制本文件为 .env 后，再按实际环境修改
# Docker Compose 会自动读取同目录下的 .env
# ==============================

# 镜像地址。
# 默认使用当前仓库发布到 GHCR 的 latest 标签。
# 你也可以改成固定版本，例如：
# PANHUB_IMAGE=ghcr.io/nowaytower/pansou-web:1.0.0
# 或固定某次提交镜像，例如：
# PANHUB_IMAGE=ghcr.io/nowaytower/pansou-web:sha-9cc21f6
PANHUB_IMAGE=ghcr.io/nowaytower/pansou-web:latest

# 容器内服务监听端口。
# 一般保持 3000 即可；如果你在 compose 里也改了端口映射，这里要和容器实际监听端口一致。
PORT=3000

# 日志级别。
# 常见可选值：debug、info、warn、error
# 正常部署建议先用 info，排查问题时再改成 debug。
LOG_LEVEL=info

# Nitro 运行目标。
# 大多数 Docker 部署场景不用手动设置，留空即可。
# 只有你明确需要自定义构建 / 运行目标时再填写。
NITRO_PRESET=

# 搜索密码门。
# 留空表示不启用访问密码。
# 如果你想给前端搜索页加一层访问口令，可以填一个密码字符串。
SEARCH_PASSWORD=

# 前端请求后端 API 的基础地址。
# 1) 前后端同域部署：保持 /api
# 2) 前后端分离部署：改成完整后端地址，例如：
#    https://api.example.com/api
NUXT_PUBLIC_API_BASE=/api

# 前端站点的对外访问地址。
# 用于 canonical、Open Graph、sitemap 等公开链接生成。
# 应填写用户实际访问前端页面的完整地址，例如：
# https://pansou.example.com
NUXT_PUBLIC_SITE_URL=https://panhub.shenzjd.com
